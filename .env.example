# App
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ASSET_PREFIX=
NEXT_PUBLIC_GA_ID=
NEXT_DEPLOYMENT_ID=

# Database
# Important: because prisma/schema.prisma lives in /prisma, local SQLite should be:
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_URL="file:/var/www/app/data/prod.db"

# Admin Auth
ADMIN_SESSION_SECRET=replace-with-random-32-character-string
# Optional bootstrap password for the very first login before an AdminUser row exists.
ADMIN_PASSWORD=change-me-before-use
